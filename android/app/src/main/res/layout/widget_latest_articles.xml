<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FeedWell"
            android:textColor="@color/widget_header"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_prev_button"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous article"
            android:scaleType="centerInside"
            android:tint="@color/widget_icon"
            android:layout_marginEnd="2dp" />

        <ImageButton
            android:id="@+id/widget_next_button"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next article"
            android:scaleType="centerInside"
            android:tint="@color/widget_icon" />

        <ImageButton
            android:id="@+id/widget_refresh_button"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:background="@null"
            android:src="@drawable/ic_widget_refresh"
            android:contentDescription="Refresh"
            android:scaleType="centerInside"
            android:tint="@color/widget_icon"
            android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- Single Article Content (compact mode) -->
    <LinearLayout
        android:id="@+id/widget_article_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_article_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No articles yet"
            android:textColor="@color/widget_title"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_article_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/widget_feed"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:visibility="gone" />

        <TextView
            android:id="@+id/widget_article_feed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="@color/widget_feed"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_article_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="@color/widget_date"
            android:textSize="10sp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Scrollable Article List (tall mode) -->
    <ListView
        android:id="@+id/widget_article_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/widget_stroke"
        android:dividerHeight="0.5dp"
        android:visibility="gone" />

    <!-- Page indicator (compact mode only) -->
    <TextView
        android:id="@+id/widget_page_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="@color/widget_indicator"
        android:textSize="9sp"
        android:paddingTop="2dp" />

</LinearLayout>
