<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FeedWell"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_prev_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Previous article"
            android:scaleType="centerInside"
            android:tint="#666666" />

        <ImageButton
            android:id="@+id/widget_next_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Next article"
            android:scaleType="centerInside"
            android:tint="#666666" />
    </LinearLayout>

    <!-- Article Content -->
    <LinearLayout
        android:id="@+id/widget_article_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_article_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No articles yet"
            android:textColor="#222222"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="3"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_article_feed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textColor="#888888"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_article_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Page indicator -->
    <TextView
        android:id="@+id/widget_page_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="#BBBBBB"
        android:textSize="10sp"
        android:paddingTop="4dp" />

</LinearLayout>
